{
    "version": "v0-bootstrap",
    "pageTemplate": "blog/post.html",
    "page": {
        "locale": "en-US",
        "title": {"template": "My Blog | {{ post.title }}"},
        "description": {"template": "{{ post.title }} | {{ post.description }}"},
        "open_graph": {
            "type": "article"
        }
    },
    "post": {
        "title": "Hello World!",
        "description": "This is my first blog post"
    },
    "includes": {
        "post_body": { "filename": "post-body.md" }
    }
}
