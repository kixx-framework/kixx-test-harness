    "version": "v0-bootstrap",
    "pageTemplate": "blog/post.html",
    "page": {
        "locale": "en-US",
        "title": {"template": "My Blog | {{ title }}"},
        "description": {"template": "{{ title }} | {{ description }}"}
    },
    "title": "Hello World!",
